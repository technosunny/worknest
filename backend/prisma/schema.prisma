// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  starter
  growth
  business
  enterprise
}

enum OrgStatus {
  active
  suspended
  trial
}

enum UserRole {
  super_admin
  org_admin
  employee
}

enum UserStatus {
  active
  inactive
  exited
}

enum AttendanceStatus {
  present
  half_day
  absent
  weekend
  holiday
}

model Organisation {
  id              String      @id @default(uuid())
  name            String
  slug            String      @unique
  logo_url        String?
  brand_colour    String?
  timezone        String      @default("Asia/Kolkata")
  plan            Plan        @default(starter)
  status          OrgStatus   @default(trial)
  subscription_id String?
  office_lat      Float?
  office_lng      Float?
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  users      User[]
  attendance Attendance[]
  rosters    Roster[]

  @@map("organisations")
}

model User {
  id                   String     @id @default(uuid())
  org_id               String?
  email                String     @unique
  phone                String?
  password_hash        String
  role                 UserRole   @default(employee)
  first_name           String
  last_name            String
  employee_id               String?
  designation               String?
  department                String?
  shift                     String?
  reporting_manager_id      String?
  status                    UserStatus @default(active)
  avatar_url                String?
  father_or_guardian_name   String?
  gender                    String?
  date_of_birth             DateTime?  @db.Date
  current_address           String?
  permanent_address         String?
  date_of_joining           DateTime?  @db.Date
  emergency_contact_name    String?
  emergency_contact_phone   String?
  emergency_contact_relation String?
  personal_email            String?
  pan_number                String?
  aadhaar_number            String?
  highest_qualification     String?
  uan_number                String?
  bank_account_number       String?
  bank_name                 String?
  bank_ifsc_code            String?
  created_at                DateTime   @default(now())
  updated_at                DateTime   @updatedAt

  organisation     Organisation? @relation(fields: [org_id], references: [id])
  reporting_manager User?        @relation("ReportingManager", fields: [reporting_manager_id], references: [id])
  direct_reports    User[]       @relation("ReportingManager")
  attendance        Attendance[]
  rosters          Roster[]

  @@unique([org_id, employee_id])
  @@map("users")
}

model Attendance {
  id                 String           @id @default(uuid())
  org_id             String
  user_id            String
  check_in_time      DateTime?
  check_out_time     DateTime?
  check_in_lat       Float?
  check_in_lng       Float?
  check_out_lat      Float?
  check_out_lng      Float?
  check_in_selfie_url String?
  total_hours        Float?
  status             AttendanceStatus @default(present)
  date               DateTime         @db.Date
  created_at         DateTime         @default(now())

  organisation Organisation @relation(fields: [org_id], references: [id])
  user         User         @relation(fields: [user_id], references: [id])

  @@unique([org_id, user_id, date])
  @@map("attendance")
}

model Roster {
  id          String   @id @default(uuid())
  org_id      String
  user_id     String
  date        DateTime @db.Date
  shift_type  String   // dayshift, nightshift, WOF
  shift_start String?  // e.g. "06:00"
  shift_end   String?  // e.g. "18:00"
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  organisation Organisation @relation(fields: [org_id], references: [id])
  user         User         @relation(fields: [user_id], references: [id])

  @@unique([org_id, user_id, date])
  @@map("rosters")
}
